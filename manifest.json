<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<meta name="theme-color" content="#1a3a2a"/>
<meta name="description" content="Álbum Tracker FIFA Mundial 2026"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="apple-mobile-web-app-title" content="Mundial 2026"/>
<link rel="manifest" href="manifest.json"/>
<link rel="apple-touch-icon" href="icons/icon-192.png"/>
<title>FIFA 2026 — Álbum Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@500&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="css/style.css"/>
</head>
<body>

<!-- LOGIN SCREEN -->
<div id="login-screen">
  <div class="login-card">
    <div class="login-logo">🏆</div>
    <h1 class="login-title">FIFA 2026</h1>
    <p class="login-sub">Álbum Tracker</p>
    <div id="login-error" class="login-error" style="display:none"></div>
    <div id="login-form">
      <input type="email" id="login-email" placeholder="Tu email" class="login-input"/>
      <input type="password" id="login-pass" placeholder="Contraseña" class="login-input"/>
      <button class="login-btn" onclick="loginUser()">Entrar</button>
      <button class="login-btn-sec" onclick="showRegister()">Crear cuenta nueva</button>
    </div>
    <div id="register-form" style="display:none">
      <input type="text" id="reg-name" placeholder="Tu nombre" class="login-input"/>
      <input type="email" id="reg-email" placeholder="Tu email" class="login-input"/>
      <input type="password" id="reg-pass" placeholder="Contraseña (mín. 6 caracteres)" class="login-input"/>
      <button class="login-btn" onclick="registerUser()">Crear cuenta</button>
      <button class="login-btn-sec" onclick="showLogin()">Ya tengo cuenta</button>
    </div>
    <div id="login-loading" style="display:none;text-align:center;color:#6b7280;padding:16px">Cargando...</div>
  </div>
</div>

<!-- APP -->
<div id="app" style="display:none">
  <!-- MOBILE HEADER -->
  <div class="mobile-header">
    <button class="burger" onclick="toggleSidebar()">☰</button>
    <span class="mobile-title">FIFA 2026</span>
    <div class="user-avatar" id="m-avatar">?</div>
  </div>

  <!-- SIDEBAR OVERLAY -->
  <div class="sidebar-overlay" id="overlay" onclick="closeSidebar()"></div>

  <div class="layout">
    <div class="sidebar" id="sidebar">
      <div class="logo">
        <div class="logo-icon">🏆</div>
        <div class="logo-text">
          <div class="logo-title">FIFA 2026</div>
          <div class="logo-sub">Álbum Tracker</div>
        </div>
      </div>
      <nav>
        <div class="nav-item active" onclick="goPage('inicio',this)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>
          Inicio
        </div>
        <div class="nav-item" onclick="goPage('paises',this)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/></svg>
          Países
        </div>
        <div class="nav-item" onclick="goPage('especiales',this)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
          Especiales
        </div>
        <div class="nav-item" onclick="goPage('cracks',this)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          Cracks
        </div>
        <div class="nav-item" onclick="goPage('costos',this)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          Costos
        </div>
        <div class="nav-item" onclick="goPage('estadisticas',this)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          Estadísticas
        </div>
      </nav>
      <div class="sidebar-bottom">
        <div class="user-row">
          <div class="user-ava" id="s-avatar">?</div>
          <div class="user-info">
            <div class="user-name" id="s-name">Usuario</div>
            <div class="user-email" id="s-email">email</div>
          </div>
        </div>
        <div class="nav-item logout-btn" onclick="logoutUser()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16,17 21,12 16,7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Cerrar sesión
        </div>
      </div>
    </div>

    <div class="main">

      <!-- INICIO -->
      <div class="page active" id="page-inicio">
        <div class="page-title">Mundial 2026</div>
        <div class="page-sub">Resumen de tu colección</div>
        <div class="hero-card">
          <div class="hero-label">Progreso Total</div>
          <div class="hero-pct" id="hero-pct">0%</div>
          <div class="hero-count" id="hero-count">0 de 980 figuritas</div>
          <div class="hero-bar"><div class="hero-fill" id="hero-fill" style="width:0%"></div></div>
          <div class="hero-trophy">🏆</div>
        </div>
        <div class="stats-row">
          <div class="stat-card"><div class="stat-icon">✅</div><div class="stat-num green" id="s-obtenidas">0</div><div class="stat-label">Obtenidas</div></div>
          <div class="stat-card"><div class="stat-icon">❌</div><div class="stat-num red" id="s-faltantes">980</div><div class="stat-label">Faltantes</div></div>
          <div class="stat-card"><div class="stat-icon">📋</div><div class="stat-num amber" id="s-repetidas">0</div><div class="stat-label">Repetidas</div></div>
        </div>
        <div class="cats-row">
          <div class="cat-card"><div class="cat-icon escudos">🛡️</div><div class="cat-info"><div class="cat-name">Escudos</div><div class="cat-val" id="cat-escudos">0/48</div></div></div>
          <div class="cat-card"><div class="cat-icon equipos">👥</div><div class="cat-info"><div class="cat-name">Equipos</div><div class="cat-val" id="cat-equipos">0/48</div></div></div>
          <div class="cat-card"><div class="cat-icon especiales">⭐</div><div class="cat-info"><div class="cat-name">Especiales</div><div class="cat-val" id="cat-esp">0/20</div></div></div>
          <div class="cat-card"><div class="cat-icon cracks">🌟</div><div class="cat-info"><div class="cat-name">Cracks</div><div class="cat-val" id="cat-cracks">0/24</div></div></div>
        </div>
        <div class="charts-row">
          <div class="chart-card"><div class="chart-title"><span>📈</span> Top 5 más completos</div><div id="top5"></div></div>
          <div class="chart-card"><div class="chart-title"><span>📉</span> 5 más atrasadas</div><div id="bot5"></div></div>
        </div>
        <div id="sync-status" class="sync-status"></div>
      </div>

      <!-- PAÍSES -->
      <div class="page" id="page-paises">
        <div class="page-title">Países</div>
        <div class="page-sub">Toca una figurita para marcarla</div>
        <div class="countries-header">
          <input class="search-box" type="text" placeholder="🔍 Buscar país..." id="country-search" oninput="renderCountries()"/>
          <div class="filter-tabs">
            <button class="filter-btn active" onclick="setCountryFilter('all',this)">Todos</button>
            <button class="filter-btn" onclick="setCountryFilter('incomplete',this)">Incompletos</button>
            <button class="filter-btn" onclick="setCountryFilter('done',this)">Completos</button>
          </div>
        </div>
        <div class="countries-grid" id="countries-grid"></div>
      </div>

      <!-- ESPECIALES -->
      <div class="page" id="page-especiales">
        <div class="page-title">Especiales</div>
        <div class="page-sub">Figuritas especiales del álbum</div>
        <div class="countries-grid" id="esp-grid"></div>
      </div>

      <!-- CRACKS -->
      <div class="page" id="page-cracks">
        <div class="page-title">Cracks</div>
        <div class="page-sub">Los mejores jugadores del Mundial</div>
        <div class="countries-grid" id="cracks-grid"></div>
      </div>

      <!-- COSTOS -->
      <div class="page" id="page-costos">
        <div class="page-title">Costos</div>
        <div class="page-sub">Calcula cuánto has gastado</div>
        <div class="cost-card">
          <div class="cost-title">💰 Calculadora de gasto</div>
          <div class="cost-row"><div class="cost-label">Precio por sobre</div><input class="cost-input" type="number" id="precio-sobre" value="500" onchange="calcCostos()"/></div>
          <div class="cost-row"><div class="cost-label">Figuritas por sobre</div><input class="cost-input" type="number" id="figs-sobre" value="5" onchange="calcCostos()"/></div>
          <div class="cost-row"><div class="cost-label">Figuritas obtenidas</div><div class="cost-value" id="c-obtenidas">0</div></div>
          <div class="cost-row"><div class="cost-label">Sobres abiertos (est.)</div><div class="cost-value" id="c-sobres">0</div></div>
          <div class="cost-row last"><div class="cost-label">Gasto total estimado</div><div class="cost-value green-val" id="c-total">$0</div></div>
        </div>
        <div class="cost-card">
          <div class="cost-title">📊 Para completar el álbum</div>
          <div class="cost-row"><div class="cost-label">Figuritas faltantes</div><div class="cost-value" id="c-falt">980</div></div>
          <div class="cost-row"><div class="cost-label">Sobres adicionales</div><div class="cost-value" id="c-sobres2">196</div></div>
          <div class="cost-row last"><div class="cost-label">Costo estimado restante</div><div class="cost-value red-val" id="c-rest">$98.000</div></div>
        </div>
      </div>

      <!-- ESTADÍSTICAS -->
      <div class="page" id="page-estadisticas">
        <div class="page-title">Estadísticas</div>
        <div class="page-sub">Análisis de tu colección</div>
        <div id="est-content"></div>
      </div>

    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="js/data.js"></script>
<script src="js/app.js"></script>
<script>
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('sw.js').catch(()=>{});
  }
</script>
</body>
</html>
